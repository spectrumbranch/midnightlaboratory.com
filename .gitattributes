# Handle line endings automatically for files detected as text
# and force them to use LF line endings on checkout.
* text=auto eol=lf

# Explicitly ensure common text-based files use LF
*.js text eol=lf
*.ts text eol=lf
*.json text eol=lf
*.md text eol=lf
*.sh text eol=lf

# Denote binary files to prevent Git from altering them
*.png binary
*.jpg binary
*.gif binary
